<% layout("layouts/boilerplate.ejs") %>
<form
  method="post"
  action="/listings/<%=listingId._id%>?_method=put"
  novalidate
  class="needs-validation"
  enctype="multipart/form-data"
>
  <div class="row mt-3">
    <div class="col-8 offset-2">
      <h3>Edit Your Listing:</h3>
      <div class="mb-3">
        <label for="category" class="form-label">Category</label>
        <select name="listing[category]" class="form-select" required>
          <option value="room" <%= listingId.category === "room" ? "selected" : "" %>>Room</option>
          <option value="iconic_cities" <%= listingId.category === "iconic_cities" ? "selected" : "" %>>Iconic Cities</option>
          <option value="mountains" <%= listingId.category === "mountains" ? "selected" : "" %>>Mountains</option>
          <option value="castles" <%= listingId.category === "castles" ? "selected" : "" %>>Castles</option>
          <option value="amazing_pools" <%= listingId.category === "amazing_pools" ? "selected" : "" %>>Amazing Pools</option>
          <option value="camping" <%= listingId.category === "camping" ? "selected" : "" %>>Camping</option>
          <option value="farms" <%= listingId.category === "farms" ? "selected" : "" %>>Farms</option>
          <option value="arctic" <%= listingId.category === "arctic" ? "selected" : "" %>>Arctic</option>
          <option value="other" <%= listingId.category === "other" ? "selected" : "" %>>Other</option>
        </select>
        <div class="invalid-feedback">Please choose a category.</div>
      </div>

      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          name="listing[title]"
          value="<%= listingId.title %>"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please provide a valid Title.</div>
      </div>

      <div class="mb-3">
        <label for="desc" class="form-label">Description</label>
        <textarea
          name="listing[description]"
          type="text"
          class="form-control"
          required
        >
<%= listingId.description %></textarea
        >
        <div class="invalid-feedback">Please provide a valid Description.</div>
      </div>

      <div class="mb-3">
        Original Listing Image <br />
        <img src="<%=originaImageUrl%>" alt="edit_image" />
      </div>

      <div class="mb-3">
        <label for="img" class="form-label">Upload new Image</label>
        <input name="listing[image]" type="file" class="form-control" />
      </div>

      <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input
          name="listing[price]"
          value="<%= listingId.price %>"
          type="number"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please provide a valid Price.</div>
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="location" class="form-label">Location</label>
          <input
            name="listing[location]"
            value="<%= listingId.location %>"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please provide a valid Location.</div>
        </div>

        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            name="listing[country]"
            value="<%= listingId.country %>"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please provide a valid Country.</div>
        </div>
      </div>

      <button class="btn btn-dark mt-3 edit-btn">Edit</button>
    </div>
  </div>
</form>
