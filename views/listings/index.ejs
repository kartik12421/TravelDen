<% layout("layouts/boilerplate.ejs") %>
  <style>
    #filters {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 2rem;
      align-self: center;
    }

    .filter {
      text-align: center;
      cursor: pointer;
      opacity: 0.6;
    }

    .filter:hover {
      opacity: 1;
      cursor: pointer;
    }

    .filter.active {
      opacity: 1;
      font-weight: 600;
    }

    .tax-info {
      display: none;
      color: green;
      font-weight: 600
    }

    .tax-toggle {
      border: 1px solid black;
      border-radius: 1rem;
      height:3.5rem;
      padding: 1rem;
      display: flex;
      align-items: center;
    }
  </style>
  <!-- <h1>all listings</h1> -->
  <div id="filters" class="filters">
    <div class="filter <%= categoryQuery === 'trending' || !categoryQuery ? 'active' : '' %>" data-filter="trending">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </div>
    <div class="filter <%= categoryQuery === 'room' ? 'active' : '' %>" data-filter="room">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Room</p>
    </div>
    <div class="filter <%= categoryQuery === 'iconic_cities' ? 'active' : '' %>" data-filter="iconic_cities">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
    </div>
    <div class="filter <%= categoryQuery === 'mountains' ? 'active' : '' %>" data-filter="mountains">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </div>
    <div class="filter <%= categoryQuery === 'castles' ? 'active' : '' %>" data-filter="castles">
      <div><i class="fa-brands fa-fort-awesome"></i></div>
      <p>Castles</p>
    </div>
    <div class="filter <%= categoryQuery === 'amazing_pools' ? 'active' : '' %>" data-filter="amazing_pools">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing Pools</p>
    </div>

    <div class="filter <%= categoryQuery === 'camping' ? 'active' : '' %>" data-filter="camping">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </div>
    <div class="filter <%= categoryQuery === 'farms' ? 'active' : '' %>" data-filter="farms">
      <div><i class="fa-solid fa-tractor"></i></div>
      <p>farms</p>
    </div>
    <div class="filter <%= categoryQuery === 'arctic' ? 'active' : '' %>" data-filter="arctic">
      <div><i class="fa-solid fa-snowman"></i></div>
      <p>Artices</p>
    </div>
    <div class="filter <%= categoryQuery === 'other' ? 'active' : '' %>" data-filter="other">
      <div><i class="fa-solid fa-umbrella-beach"></i></div>
      <p>Other...</p>
    </div>

    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">display Total Taxes</label>
      </div>
    </div>

  </div>

  <form class="row g-2 mt-3 mb-2" action="/listings" method="GET">
    <input type="hidden" name="category" value="<%= categoryQuery || '' %>" />
    <div class="col-md-4">
      <input
        type="search"
        class="form-control"
        name="search"
        placeholder="Keyword (title/location/country)"
        value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
      />
    </div>
    <div class="col-md-3">
      <input
        type="search"
        class="form-control"
        name="location"
        placeholder="Location"
        value="<%= typeof locationQuery !== 'undefined' ? locationQuery : '' %>"
      />
    </div>
    <div class="col-md-3">
      <input
        type="search"
        class="form-control"
        name="country"
        placeholder="Country"
        value="<%= typeof countryQuery !== 'undefined' ? countryQuery : '' %>"
      />
    </div>
    <div class="col-md-2 d-grid">
      <button class="btn btn-dark" type="submit">Apply Filters</button>
    </div>
  </form>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% if (allListings.length === 0) { %>
      <p class="text-center fs-5 mt-4">
        No listings found.
      </p>
    <% } %>
    <%for(let listing of allListings){%>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card listing-card` col">
          <img src="<%= listing.image.url %>" class="card-img-top" alt="image" style="height: 20rem" />
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b>
                <%= listing.title %>
              </b> <br />
              &#8377; <%=listing.price.toLocaleString("en-IN") %>
              <i class="tax-info">&nbsp; &nbsp;+18% GST</i>
            </p>
          </div>
        </div>
      </a>
      <%}%>
  </div>

  <script>
    const filterItems = document.querySelectorAll("#filters .filter[data-filter]");
    filterItems.forEach((item) => {
      item.addEventListener("click", () => {
        const selectedFilter = item.dataset.filter;
        const params = new URLSearchParams(window.location.search);

        if (selectedFilter === "trending") {
          params.delete("category");
        } else {
          params.set("category", selectedFilter);
        }

        window.location.href = `/listings?${params.toString()}`;
      });
    });

    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("change", () => {
      let taxinfo = document.getElementsByClassName("tax-info");
      for (let info of taxinfo) {
        if (info.style.display != "inline") {
          info.style.display = "inline";
        } else {
          info.style.display = "none";
        }
      }
    })

  </script>
